```gitignore
# ==========================================================
# QuizWiz - .gitignore
# Java Servlet / JSP / JDBC / MySQL Project
# ==========================================================

##############################
# Java
##############################
*.class
*.log
*.ctxt
*.jar
*.war
*.ear

##############################
# IntelliJ IDEA
##############################
.idea/
*.iml
out/

##############################
# Eclipse
##############################
.project
.classpath
.settings/
bin/

##############################
# NetBeans
##############################
nbproject/private/
build/
dist/
nbbuild/
nbdist/

##############################
# VS Code
##############################
.vscode/

##############################
# Maven
##############################
target/

##############################
# Gradle
##############################
.gradle/
build/

##############################
# Apache Tomcat
##############################
work/
temp/
logs/
webapps/

##############################
# Operating System Files
##############################
.DS_Store
Thumbs.db
Desktop.ini

##############################
# Environment Variables
##############################
.env
.env.*
!.env.example

##############################
# Database Files
##############################
*.db
*.sqlite
*.sqlite3

##############################
# MySQL Dumps
##############################
*.sql.bak

##############################
# Local Configuration
##############################
config.properties
database.properties
application-local.properties

##############################
# Sensitive Files
##############################
*.pem
*.key
*.crt
*.p12
*.jks

##############################
# Logs
##############################
*.log
logs/

##############################
# Temporary Files
##############################
*.tmp
*.temp
*.swp
*.swo
*~

##############################
# Coverage Reports
##############################
coverage/
htmlcov/

##############################
# Generated Documentation
##############################
site/

##############################
# Node Modules (if frontend added)
##############################
node_modules/

##############################
# Package Managers
##############################
package-lock.json
yarn.lock
pnpm-lock.yaml

##############################
# Mac/Linux Hidden Files
##############################
.AppleDouble
.LSOverride

##############################
# Windows Hidden Files
##############################
ehthumbs.db


##############################
#target
##############################
target/
```
