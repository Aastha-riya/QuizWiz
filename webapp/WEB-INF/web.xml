<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>QuizWiz Online Assessment Platform</display-name>

    <!-- ================================================================
         CONTEXT PARAMETERS
         Global values readable by any servlet via
         getServletContext().getInitParameter("name").
         ================================================================ -->

    <!-- #11 Quiz duration in seconds (default 600 = 10 minutes).
         Servlets and JSPs read this instead of hardcoding the value. -->
    <context-param>
        <param-name>quizDuration</param-name>
        <param-value>600</param-value>
    </context-param>

    <!-- Application display name used in page titles / emails -->
    <context-param>
        <param-name>appName</param-name>
        <param-value>QuizWiz</param-value>
    </context-param>


    <!-- ================================================================
         SERVLETS
         ================================================================ -->

    <!-- #1 LoginServlet — handles GET (show form) and POST (authenticate) -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.quizwiz.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- #2 RegisterServlet — handles new student self-registration -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.quizwiz.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- #3 LogoutServlet — invalidates session and redirects to /login -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.quizwiz.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- QuizServlet — loads questions and forwards to quiz.jsp -->
    <servlet>
        <servlet-name>QuizServlet</servlet-name>
        <servlet-class>com.quizwiz.servlet.QuizServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>QuizServlet</servlet-name>
        <url-pattern>/quiz</url-pattern>
    </servlet-mapping>

    <!-- SubmitServlet — scores the quiz and forwards to result.jsp.
         Also validates started_at for server-side time enforcement (#13). -->
    <servlet>
        <servlet-name>SubmitServlet</servlet-name>
        <servlet-class>com.quizwiz.servlet.SubmitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubmitServlet</servlet-name>
        <url-pattern>/submit</url-pattern>
    </servlet-mapping>

    <!-- #4 AdminServlet — admin dashboard; protected by AuthFilter below -->
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.quizwiz.servlet.AdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>


    <!-- ================================================================
         FILTERS
         Filters run in declaration order for matching requests.
         ================================================================ -->

    <!-- #10 EncodingFilter — forces UTF-8 on every request and response.
         Supports English, Hindi, emoji, and all other Unicode text. -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.quizwiz.filter.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- #5 AuthFilter — restricts /admin/* to logged-in admins only.
         Redirects unauthenticated requests to /login. -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.quizwiz.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- #6 StudentFilter — restricts /quiz, /submit, /result, and /profile
         to authenticated students. Redirects anonymous users to /login. -->
    <filter>
        <filter-name>StudentFilter</filter-name>
        <filter-class>com.quizwiz.filter.StudentFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>StudentFilter</filter-name>
        <url-pattern>/quiz</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>StudentFilter</filter-name>
        <url-pattern>/submit</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>StudentFilter</filter-name>
        <url-pattern>/result</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>StudentFilter</filter-name>
        <url-pattern>/profile</url-pattern>
    </filter-mapping>


    <!-- ================================================================
         LISTENERS
         ================================================================ -->

    <!-- #12 SessionListener — counts currently online users.
         Increments on sessionCreated, decrements on sessionDestroyed.
         Admin dashboard reads the count from the application scope. -->
    <listener>
        <listener-class>com.quizwiz.listener.SessionListener</listener-class>
    </listener>


    <!-- ================================================================
         SESSION CONFIG
         ================================================================ -->

    <!-- #7 Session timeout: 30 minutes of inactivity invalidates the session. -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>


    <!-- ================================================================
         MIME MAPPINGS
         ================================================================ -->

    <!-- #13 PDF certificates and CSV reports served with correct MIME types -->
    <mime-mapping>
        <extension>pdf</extension>
        <mime-type>application/pdf</mime-type>
    </mime-mapping>
    <mime-mapping>
        <extension>csv</extension>
        <mime-type>text/csv</mime-type>
    </mime-mapping>


    <!-- ================================================================
         ERROR PAGES
         ================================================================ -->

    <error-page>
        <error-code>400</error-code>
        <location>/error400.jsp</location>
    </error-page>

    <!-- #14 401 Unauthorized — shown when authentication is required -->
    <error-page>
        <error-code>401</error-code>
        <location>/error401.jsp</location>
    </error-page>

    <!-- #14 403 Forbidden — shown when a logged-in user lacks permission -->
    <error-page>
        <error-code>403</error-code>
        <location>/accessDenied.jsp</location>
    </error-page>

    <error-page>
        <error-code>404</error-code>
        <location>/error404.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/error500.jsp</location>
    </error-page>


    <!-- ================================================================
         WELCOME FILE
         ================================================================ -->

    <!-- #8 index.jsp acts as the home page and routes to login/dashboard -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
